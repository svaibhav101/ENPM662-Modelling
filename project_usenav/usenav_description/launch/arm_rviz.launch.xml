<launch>
    <let name="urdf_path" value="$(find-pkg-share usenav_description)/urdf/arm/standalone_arm.xacro" />
    <let name="rviz_config_path" value="$(find-pkg-share usenav_description)/config/display.rviz" />

    <node name="robot_state_publisher" pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <node name="joint_state_publisher_gui" pkg="joint_state_publisher_gui"
        exec="joint_state_publisher_gui" />

    <node name="rviz2" pkg="rviz2"
        exec="rviz2"
        args="-d $(var rviz_config_path)"
        output="screen" />


</launch>